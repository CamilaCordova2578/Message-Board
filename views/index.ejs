<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>Messages:</h1>
    <div>
         <%messages.forEach(message => { %>
            <p><strong>Text:</strong><%=message.text%></p>
            <p><strong>User:</strong><%= message.user %></p>
            <p><strong>Added:</strong><%= message.added %></p>
        <%}) %>
    </div>
    <a href="/new">New message</a>
       
    
</body>
</html>